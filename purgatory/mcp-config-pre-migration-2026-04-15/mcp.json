{
  "mcpServers": {
    "brave-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp-for-brave@0.4.2"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@2.1.7"]
    },
    "mattermost": {
      "command": "npx",
      "args": ["@dakatan/mcp-mattermost@0.0.5"],
      "env": {
        "MCP_MATTERMOST_URL": "${MCP_MATTERMOST_URL}",
        "MCP_MATTERMOST_TOKEN": "${MCP_MATTERMOST_TOKEN}",
        "MCP_MATTERMOST_TEAM_ID": "${MCP_MATTERMOST_TEAM_ID}"
      }
    },
    "ollama-local": {
      "command": "bun",
      "args": ["run", "/home/jean-marc/qara/.claude/mcp-servers/ollama-local/index.ts"],
      "env": {
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_MODEL": "gemma4:latest"
      }
    },
    "jcodemunch": {
      "command": "uv",
      "args": ["tool", "run", "jcodemunch-mcp"]
    }
  }
}
